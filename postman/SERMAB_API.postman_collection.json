{
  "info": {
    "name": "SERMAB API",
    "description": "Colección completa de endpoints para el sistema SERMAB. \n\n**Cómo usar:**\n1. Importa esta colección en Postman\n2. Configura la variable `baseUrl` si es necesario (default: http://localhost:3000)\n3. Ejecuta **Auth > Login** primero para obtener el token JWT\n4. El token se guarda automáticamente en la variable `token` de la colección\n5. Todas las demás peticiones lo usan automáticamente",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "baseUrl",
      "value": "http://localhost:3000/api",
      "type": "string"
    },
    {
      "key": "token",
      "value": "",
      "type": "string"
    }
  ],
  "auth": {
    "type": "bearer",
    "bearer": [
      {
        "key": "token",
        "value": "{{token}}",
        "type": "string"
      }
    ]
  },
  "item": [
    {
      "name": "🔐 Auth",
      "item": [
        {
          "name": "Register",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "if (pm.response.code === 201) {",
                  "  const json = pm.response.json();",
                  "  pm.collectionVariables.set('token', json.token);",
                  "  console.log('✅ Token guardado automáticamente al registrarse');",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "auth": { "type": "noauth" },
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"rolusr_id\": 1,\n  \"usuari_nm\": \"Juan\",\n  \"usuari_ap\": \"Pérez\",\n  \"usuari_cd\": \"jperez01\",\n  \"usuari_co\": \"contraseña123\",\n  \"usuari_em\": \"juan@ejemplo.com\"\n}"
            },
            "url": { "raw": "{{baseUrl}}/auth/register", "host": ["{{baseUrl}}"], "path": ["auth", "register"] }
          }
        },
        {
          "name": "Login",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "if (pm.response.code === 200) {",
                  "  const json = pm.response.json();",
                  "  pm.collectionVariables.set('token', json.token);",
                  "  console.log('✅ Token guardado automáticamente');",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "auth": { "type": "noauth" },
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"usuari_cd\": \"admin01\",\n  \"usuari_co\": \"mi_contraseña\"\n}"
            },
            "url": { "raw": "{{baseUrl}}/auth/login", "host": ["{{baseUrl}}"], "path": ["auth", "login"] }
          }
        },
        {
          "name": "Ver Perfil (GET /auth/profile)",
          "request": {
            "method": "GET",
            "url": { "raw": "{{baseUrl}}/auth/profile", "host": ["{{baseUrl}}"], "path": ["auth", "profile"] }
          }
        },
        {
          "name": "Actualizar Perfil (PUT /auth/profile)",
          "request": {
            "method": "PUT",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"usuari_nm\": \"Juan Actualizado\",\n  \"usuari_ap\": \"Pérez López\"\n}"
            },
            "url": { "raw": "{{baseUrl}}/auth/profile", "host": ["{{baseUrl}}"], "path": ["auth", "profile"] }
          }
        },
        {
          "name": "Cambiar Contraseña (PUT /auth/change-password)",
          "request": {
            "method": "PUT",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"currentPassword\": \"contraseña_actual\",\n  \"newPassword\": \"nueva_contraseña_segura\"\n}"
            },
            "url": { "raw": "{{baseUrl}}/auth/change-password", "host": ["{{baseUrl}}"], "path": ["auth", "change-password"] }
          }
        },
        {
          "name": "Recuperar Contraseña (POST /auth/recover)",
          "request": {
            "auth": { "type": "noauth" },
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"usuario@ejemplo.com\"\n}"
            },
            "url": { "raw": "{{baseUrl}}/auth/recover", "host": ["{{baseUrl}}"], "path": ["auth", "recover"] }
          }
        },
        {
          "name": "Resetear Contraseña (POST /auth/reset)",
          "request": {
            "auth": { "type": "noauth" },
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"token\": \"TOKEN_DE_RECUPERACION_AQUI\",\n  \"newPassword\": \"nueva_contraseña_segura\"\n}"
            },
            "url": { "raw": "{{baseUrl}}/auth/reset", "host": ["{{baseUrl}}"], "path": ["auth", "reset"] }
          }
        },
        {
          "name": "Health Check",
          "request": {
            "auth": { "type": "noauth" },
            "method": "GET",
            "url": { "raw": "{{baseUrl}}/health", "host": ["{{baseUrl}}"], "path": ["health"] }
          }
        }
      ]
    },
