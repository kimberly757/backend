# Variables de entorno de ejemplo para SERMAB Backend
# Copia este archivo como .env y completa los valores

# ─── Servidor ─────────────────────────────────────────────
PORT=3000
NODE_ENV=development

# ─── Base de Datos PostgreSQL ──────────────────────────────
# Para Neon: usa el host del pool de conexiones
DB_HOST=ep-xxxx-pooler.c-9.us-east-1.aws.neon.tech
DB_PORT=5432
DB_NAME=neondb
DB_USER=neondb_owner
DB_PASSWORD=tu_password_aqui

# ─── JWT ───────────────────────────────────────────────────
JWT_SECRET=cambia_esto_por_una_clave_segura_min_16_chars
JWT_EXPIRES_IN=24h

# ─── Email ─────────────────────────────────────────────────
# Opciones: log | smtp | emailjs
EMAIL_TRANSPORT=log

# SMTP (requerido si EMAIL_TRANSPORT=smtp)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=tu_correo@gmail.com
SMTP_PASS=tu_app_password

# EmailJS (requerido si EMAIL_TRANSPORT=emailjs)
EMAILJS_SERVICE_ID=
EMAILJS_TEMPLATE_ID=
EMAILJS_PUBLIC_KEY=
EMAILJS_PRIVATE_KEY=

# ─── Frontend ──────────────────────────────────────────────
FRONTEND_URL=http://localhost:5173
